{
  "$schema": "https://raw.githubusercontent.com/vicinaehq/vicinae/refs/heads/main/extra/schemas/extension.json",
  "name": "vicinae-bitwarden",
  "title": "Bitwarden",
  "description": "Quick access to your Bitwarden vault",
  "author": "flo",
  "license": "MIT",
  "icon": "extension_icon.svg",
  "commands": [
    {
      "name": "search",
      "title": "Search Vault",
      "subtitle": "Bitwarden",
      "description": "Search items in your Bitwarden vault",
      "mode": "view",
      "arguments": [
        {
          "name": "query",
          "placeholder": "Search query",
          "type": "text"
        }
      ]
    }
  ],
  "scripts": {
    "build": "vici build",
    "dev": "vici develop",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vicinae/api": "0.16.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.9.3"
  }
}
